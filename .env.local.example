# Copy to .env.local and fill in after running `npx convex dev`.
# Convex CLI auto-populates these on first deploy.

# Convex deployment slug (dev/prod) — server-side only
CONVEX_DEPLOYMENT=

# Public Convex URL — exposed to the browser via NEXT_PUBLIC_*
NEXT_PUBLIC_CONVEX_URL=

# ── PayPal billing ──────────────────────────────────────────────────
# These live as Convex env vars (set with `npx convex env set KEY=value`),
# NOT in this Next.js .env. Listed here as documentation only.
#
# PAYPAL_MODE          = sandbox | live   (defaults to sandbox)
# PAYPAL_CLIENT_ID     = REST app client id
# PAYPAL_CLIENT_SECRET = REST app secret
# PAYPAL_WEBHOOK_ID    = id of the webhook configured at
#                        api-m.{sandbox.,}paypal.com/v1/notifications/webhooks
# PAYPAL_PLAN_ID_TEAM  = id of the Team subscription plan (P-XXXX...)
# PAYPAL_PLAN_ID_SCALE = id of the Scale subscription plan (P-XXXX...)
# PAYPAL_RETURN_URL    = where PayPal redirects after approval
#                        (e.g. https://app.praxtalk.com/app/billing?paypal=approved)
# PAYPAL_CANCEL_URL    = where PayPal redirects on user cancel
